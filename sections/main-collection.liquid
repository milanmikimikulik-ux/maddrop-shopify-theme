{%- paginate collection.products by section.settings.products_per_page -%}
<div class="collection-page">
  <div class="collection-header">
    <h1 class="collection-header__title">
      {%- if section.settings.page_title != blank -%}
        {{ section.settings.page_title }}
      {%- else -%}
        {{ collection.title }}
      {%- endif -%}
    </h1>
    <div class="collection-header__desc">
      {%- if section.settings.page_description != blank -%}
        {{ section.settings.page_description }}
      {%- elsif collection.description != blank -%}
        {{ collection.description }}
      {%- else -%}
        <p>Unlock unlimited benefits with Mad Drop. Our nootropic and healthy drinks are designed to fuel your mind and body.</p>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_filters and collection.all_tags.size > 0 -%}
    <div class="collection-filters">
      <a href="{{ collection.url }}" class="collection-filter-btn{%- unless current_tags -%} is-active{%- endunless -%}">All</a>
      {%- for tag in collection.all_tags -%}
        <a href="{{ collection.url }}/{{ tag | handle }}"
          class="collection-filter-btn{%- if current_tags contains tag %} is-active{%- endif -%}">
          {{ tag }}
        </a>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <div class="product-grid" style="--cols-desktop:{{ section.settings.columns_desktop }}; --cols-mobile:{{ section.settings.columns_mobile }}">
    {%- for product in collection.products -%}
      <div class="product-card">
        <a href="{{ product.url }}" class="product-card__link">
          <div class="product-card__image-wrap">
            {%- if product.featured_image -%}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | escape }}"
                class="product-card__image"
                loading="lazy"
                width="600"
                height="600"
              >
            {%- else -%}
              <div class="product-card__image-placeholder">
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
          <div class="product-card__info">
            <h3 class="product-card__title">{{ product.title | upcase }}</h3>
            <p class="product-card__price">
              {%- if product.compare_at_price > product.price -%}
                <span class="price--sale">{{ product.price | money }}</span>
                <s class="price--compare">{{ product.compare_at_price | money }}</s>
              {%- else -%}
                {{ product.price | money }}
              {%- endif -%}
            </p>
          </div>
        </a>
        <form action="{{ routes.cart_add_url }}" method="post" class="product-card__form">
          <input type="hidden" name="id" value="{{ product.first_available_variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <button
            type="submit"
            class="btn-primary product-card__atc"
            {%- unless product.available %} disabled{%- endunless -%}
          >
            {%- if product.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
          </button>
        </form>
      </div>
    {%- else -%}
      <p class="collection-empty">No products found in this collection.</p>
    {%- endfor -%}
  </div>

  {%- if paginate.pages > 1 -%}
    <div class="pagination">
      {{ paginate | default_pagination }}
    </div>
  {%- endif -%}
</div>
{%- endpaginate -%}

{% schema %}
{
  "name": "Collection Page",
  "tag": "section",
  "class": "section-collection",
  "settings": [
    {
      "type": "text",
      "id": "page_title",
      "label": "Page title override",
      "info": "Leave blank to use collection title"
    },
    {
      "type": "text",
      "id": "page_description",
      "label": "Page description override",
      "info": "Leave blank to use collection description"
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show category filters",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 12,
      "label": "Products per page"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Columns on desktop"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2,
      "label": "Columns on mobile"
    }
  ]
}
{% endschema %}
