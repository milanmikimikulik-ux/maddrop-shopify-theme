<div class="cart-page"><h1>Your Cart</h1>{% if cart.item_count == 0 %}<p>Your cart is empty. <a href="{{ routes.all_products_collection_url }}">Continue shopping</a></p>{% else %}<form action="{{ routes.cart_url }}" method="post">{% for item in cart.items %}<div class="cart-item"><a href="{{ item.url }}">{{ item.title }}</a><span>{{ item.quantity }} x {{ item.price | money }}</span></div>{% endfor %}<p>Total: {{ cart.total_price | money }}</p><button type="submit" name="checkout">Checkout</button></form>{% endif %}</div>
